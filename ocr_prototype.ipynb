# =============================================================================
# Handwritten Prescription OCR - using existing CSV
# Path: /content/fda_drug_data/fda_medicine_names.csv
# =============================================================================

# ─── Imports ────────────────────────────────────────────────────────────────
import easyocr
import cv2
import numpy as np
import re
import pandas as pd
from fuzzywuzzy import process, fuzz
from google.colab import files
import os

# ─── 1. Load medicine names from your existing CSV ──────────────────────────
CSV_PATH = "/content/fda_drug_data/fda_medicine_names.csv"

try:
    df = pd.read_csv(CSV_PATH)
    # Use column 'name' or the first column
    if 'name' in df.columns:
        MEDICINE_VOCAB = df['name'].dropna().str.strip().str.title().tolist()
    else:
        MEDICINE_VOCAB = df.iloc[:, 0].dropna().str.strip().str.title().tolist()

    print(f"Loaded {len(MEDICINE_VOCAB):,} medicine names from:")
    print(f"  {CSV_PATH}\n")
except Exception as e:
    print("Error loading CSV:", str(e))
    print("Using very small fallback list instead.\n")
    MEDICINE_VOCAB = ["Losartan", "Amlodipine", "Metformin", "Atorvastatin", "Paracetamol"]

# ─── 2. Preprocess image to improve handwriting recognition ─────────────────
def preprocess_image(image_path):
    img = cv2.imread(image_path, cv2.IMREAD_GRAYSCALE)
    if img is None:
        return image_path

    # Remove noise
    img = cv2.fastNlMeansDenoising(img, h=25)

    # Improve contrast
    clahe = cv2.createCLAHE(clipLimit=2.5, tileGridSize=(8,8))
    img = clahe.apply(img)

    # Make text black on white (binary)
    thresh = cv2.adaptiveThreshold(
        img, 255,
        cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
        cv2.THRESH_BINARY_INV,
        11, 2
    )

    # Connect broken letters
    kernel = np.ones((2,2), np.uint8)
    thresh = cv2.dilate(thresh, kernel, iterations=1)

    proc_path = "processed_prescription.jpg"
    cv2.imwrite(proc_path, thresh)
    print("Preprocessed image saved:", proc_path)
    return proc_path

# ─── 3. Extract text using EasyOCR ──────────────────────────────────────────
def extract_text(image_path):
    reader = easyocr.Reader(['en'], gpu=False, verbose=False)

    texts = []

    # Run on original
    print("OCR → original image...")
    res1 = reader.readtext(image_path, detail=0, paragraph=True, min_size=6)
    texts.extend(res1)

    # Run on preprocessed (usually better for handwriting)
    proc_path = preprocess_image(image_path)
    print("OCR → preprocessed image...")
    res2 = reader.readtext(proc_path, detail=0, paragraph=True, min_size=6)
    texts.extend(res2)

    full_text = ' '.join(texts)
    full_text = re.sub(r'\s{2,}', ' ', full_text).strip()
    return full_text

# ─── 4. Clean text (fix common OCR mistakes) ────────────────────────────────
def clean_text(text):
    fixes = {
        'Ta6s': 'Tabs', 'Tals': 'Tabs', 'Tak;': 'Tabs',
        'milliglam': 'milligram', 'milliqiam': 'milligram', 'S0milhzmn': 'milligram',
        'mowth': 'mouth', 'meeirh': 'mouth', 'motizh': 'mouth',
        'momnin': 'morning', '@omomin': 'morning', "'mownin": 'morning',
        'Gix': 'six', '6i': 'six', '632': '6',
        'Wood': 'blood', 'Uood': 'blood',
        'ueessevee': 'pressure', 'pveaoewe': 'pressure',
        'conzeo': 'control', 'conzevl': 'control',
        'koe': 'for', '= J': 'for',
        'Losaxan': 'Losartan', 'Losnian': 'Losartan', 'Loanian': 'Losartan',
        'Losnuan': 'Losartan',
        'Disuense': 'Dispense', 'Dispenae': 'Dispense',
        'Refiii': 'Refill', 'Refiu': 'Refill',
    }

    for wrong, right in fixes.items():
        text = text.replace(wrong, right)

    text = re.sub(r'[^a-zA-Z0-9\s:;,.#/-]', '', text)
    text = re.sub(r'\s+', ' ', text).strip()
    return text

# ─── 5. Find and correct medicine names ─────────────────────────────────────
def find_medicines(text, vocab, min_score=72):
    corrected_text = text
    detected = []

    words = re.findall(r'\b[a-zA-Z]{4,18}\b', text)

    for word in words:
        match, score = process.extractOne(word.title(), vocab, scorer=fuzz.token_sort_ratio)
        if score >= min_score:
            detected.append(match)
            corrected_text = re.sub(r'\b' + re.escape(word) + r'\b', match, corrected_text, flags=re.I)

    return corrected_text, sorted(set(detected))

# ─── 6. Main flow ───────────────────────────────────────────────────────────
print("\n" + "="*60)
print("Upload your prescription image (jpg/png)")
print("="*60 + "\n")

uploaded = files.upload()
if not uploaded:
    print("No image selected.")
else:
    image_file = list(uploaded.keys())[0]
    print(f"\nProcessing: {image_file}\n")

    # Step 1: OCR → get raw text
    raw = extract_text(image_file)
    print("RAW TEXT:")
    print(raw)
    print("\n" + "-"*70 + "\n")

    # Step 2: Clean OCR mistakes
    cleaned = clean_text(raw)
    print("CLEANED TEXT:")
    print(cleaned)
    print("\n" + "-"*70 + "\n")

    # Step 3: Detect & correct medicine names
    final, medicines = find_medicines(cleaned, MEDICINE_VOCAB)

    print("FINAL TEXT (with corrections):")
    print(final)
    print("\nDETECTED MEDICINES:")
    if medicines:
        print(", ".join(medicines))
    else:
        print("(none found – you can lower min_score or add more fixes)")

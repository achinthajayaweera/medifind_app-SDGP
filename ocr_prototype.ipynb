import easyocr
import re
from fuzzywuzzy import process, fuzz
import cv2
import numpy as np
from google.colab import files
import matplotlib.pyplot as plt   # optional: visualize steps

# Your medical vocabulary (expand as needed)
MEDICAL_VOCAB = [
    "Losartan", "Aspirin", "Ibuprofen", "Paracetamol", "Amoxicillin", "Metformin", "Atorvastatin",
    "Omeprazole", "Lisinopril", "Levothyroxine", "Amlodipine", "Simvastatin", "Ciprofloxacin",
    "Azithromycin", "Prednisone", "Hydrochlorothiazide", "Gabapentin", "Sertraline", "Albuterol",
    "Pantoprazole", "Escitalopram", "Fluoxetine", "Tramadol", "Warfarin", "Clopidogrel",
    # Add brand names, generics, common abbreviations, etc.
]

def preprocess_image_for_ocr(image_path, visualize=False):
    """
    Preprocess image for better EasyOCR performance on prescriptions.
    Steps 5 & 6 (morphology: dilate/erode) removed as requested.
    """
    # 1. Read image
    img = cv2.imread(image_path)
    if img is None:
        raise ValueError("Could not load image")

    # 2. Convert to grayscale
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    # 3. Noise reduction
    denoised = cv2.GaussianBlur(gray, (3, 3), 0)
    # Alternative: denoised = cv2.medianBlur(gray, 3)  # sometimes better for salt & pepper noise

    # 4. Contrast enhancement with CLAHE (usually best for local handwriting contrast)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
    enhanced = clahe.apply(denoised)

    # 5. Adaptive thresholding (core step for binarization)
    binary = cv2.adaptiveThreshold(
        enhanced, 255,
        cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
        cv2.THRESH_BINARY_INV,     # inverted → white text on black bg (often better for OCR)
        blockSize=31,              # try 21, 31, 41 depending on text size/resolution
        C=9                        # try 5–12
    )

    # Save processed image for OCR
    processed_path = "processed_" + image_path
    cv2.imwrite(processed_path, binary)

    # Optional: show before/after
    if visualize:
        plt.figure(figsize=(12, 6))
        plt.subplot(121), plt.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB)), plt.title("Original")
        plt.subplot(122), plt.imshow(binary, cmap='gray'), plt.title("Processed (no morphology)")
        plt.show()

    return processed_path


def clean_and_normalize_text(text):
    text = re.sub(r'[^a-zA-Z0-9\s\./-]', '', text)
    text = re.sub(r'\s+', ' ', text).strip()
    return text.lower()


def identify_and_correct_medicines(extracted_text, vocab, threshold=78):
    words = extracted_text.split()
    detected_medicines = []
    corrected_text = extracted_text

    for word in words:
        if len(word) < 3:
            continue
        best_match, score = process.extractOne(word, vocab, scorer=fuzz.token_sort_ratio)
        if score >= threshold:
            detected_medicines.append(best_match)
            corrected_text = re.sub(re.escape(word), best_match, corrected_text, flags=re.IGNORECASE)

    return corrected_text, list(set(detected_medicines))


def extract_text_from_image(image_path):
    reader = easyocr.Reader(['en'], gpu=False)
    result = reader.readtext(image_path, detail=0)
    return ' '.join(result)


# ────────────────────────────────────────────────
# Main workflow
uploaded = files.upload()
image_path = list(uploaded.keys())[0]

# Preprocess (steps 5 & 6 removed)
processed_path = preprocess_image_for_ocr(image_path, visualize=True)  # change to False later

# OCR
raw_text = extract_text_from_image(processed_path)
print("Raw Extracted Text:\n", raw_text)

# Clean
cleaned_text = clean_and_normalize_text(raw_text)
print("\nCleaned Text:\n", cleaned_text)

# Correct medicine names
corrected_text, detected_medicines = identify_and_correct_medicines(cleaned_text, MEDICAL_VOCAB, threshold=78)

# Optional: capitalize detected medicine names for nicer output
words = corrected_text.split()
corrected_text = ' '.join(
    word.capitalize() if any(word.lower() == m.lower() for m in detected_medicines)
    else word for word in words
)

print("\nCorrected Prescription Text:\n", corrected_text)
print("\nDetected Medicines:\n", detected_medicines)

# ─── OCR Function (minimal) ──────────────────────────────────────────────────
def extract_text_easyocr(image_path):
    print("Running EasyOCR...")
    try:
        reader = easyocr.Reader(['en'], gpu=False, verbose=False)
        result = reader.readtext(image_path, detail=0, paragraph=True)
        text = "\n".join(result)
        text = " ".join(text.split())  # only normalize spaces
        return text
    except Exception as e:
        print("EasyOCR error:", str(e))
        return ""

# ─── Extract Prescriber / Facility Details ───────────────────────────────────
def extract_prescriber_details(ocr_text):
    prompt = f"""You are an expert at reading medical prescriptions from OCR text.
Extract **only** prescriber and facility related information.

Return **strictly** valid JSON — nothing else (no markdown, no explanations):

{{
  "doctor_name": "full name or null",
  "specialization": "mentioned specialty or null",
  "registration_number": "DEA / license / council number or null",
  "facility_name": "clinic / hospital / practice name or null",
  "location": "full address / city / state / zip or null",
  "prescription_date": "date in any readable format or null"
}}

OCR extracted text:
{ocr_text}
"""

    try:
        response = model.generate_content(prompt)
        result_text = response.text.strip()

        # Clean possible markdown wrapping
        if result_text.startswith("```"):
            result_text = result_text.split("```")[1].strip()
            if result_text.startswith("json"):
                result_text = result_text[4:].strip()

        print("\n" + "═"*70)
        print("PRESCRIBER / FACILITY DETAILS (extracted)")
        print("═"*70)
        print(result_text)
        print("═"*70 + "\n")

    except Exception as e:
        print("Gemini API call failed:", str(e))
        print("Common fixes:")
        print("1. Change model name to 'gemini-1.5-flash-001' or 'gemini-1.0-pro'")
        print("2. Create a new API key at https://aistudio.google.com/app/apikey")
        print("3. Check if the key has access to Gemini models")

# ─── Main Program ────────────────────────────────────────────────────────────
print("=== Upload your prescription image (jpg / png) ===\n")

uploaded = files.upload()

if uploaded:
    image_filename = list(uploaded.keys())[0]
    print(f"\nProcessing image: {image_filename}\n")

    # Step 1: OCR
    raw_text = extract_text_easyocr(image_filename)

    print("RAW OCR OUTPUT:")
    print("-" * 80)
    print(raw_text if raw_text else "(no text detected)")
    print("-" * 80 + "\n")

    # Step 2: Structured extraction
    if raw_text.strip():
        print("Extracting prescriber and facility information...")
        extract_prescriber_details(raw_text)
    else:
        print("No text was extracted from the image.")
else:
    print("No image was uploaded.")
